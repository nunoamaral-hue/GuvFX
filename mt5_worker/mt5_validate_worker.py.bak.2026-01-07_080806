import json
import time
import glob
import os
from pathlib import Path

import requests

# This is the SAME path your backend writes validate_request.json into
HANDOFF = Path("/app/.guvfx_handoff_validate")

DEFAULT_TIMEOUT = 20  # seconds (agent call timeout)

def _write_json_atomic(path: Path, payload: dict) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(payload), encoding="utf-8")
    tmp.replace(path)

def _agent_base() -> str:
    return (os.getenv("WINDOWS_AGENT_BASE") or os.getenv("GUVFX_AGENT_URL") or "").rstrip("/")

def _agent_token() -> str:
    return (os.getenv("WINDOWS_AGENT_TOKEN") or os.getenv("GUVFX_AGENT_TOKEN") or "").strip()

def _validate_via_agent(login: str, password: str, server: str) -> tuple[bool, str]:
    base = _agent_base()
    token = _agent_token()
    if not base:
        return False, "WINDOWS_AGENT_BASE (or GUVFX_AGENT_URL) is not set"
    if not token:
        return False, "WINDOWS_AGENT_TOKEN (or GUVFX_AGENT_TOKEN) is not set"

    url = f"{base}/validate-mt5"
    headers = {"X-GuvFX-Agent-Token": token, "Content-Type": "application/json"}
    payload = {"login": login, "password": password, "server": server}

    try:
        r = requests.post(url, headers=headers, json=payload, timeout=DEFAULT_TIMEOUT)
    except Exception as e:
        return False, f"windows_agent_request_failed: {type(e).__name__}: {e}"

    # Agent should return JSON
    try:
        data = r.json()
    except Exception:
        return False, f"windows_agent_bad_json status={r.status_code} body={r.text[:200]}"

    # Expected from your earlier test:
    # { ok: true, valid: bool, log_found: bool, log_tail: str }
    ok = bool(data.get("ok", False))
    valid = bool(data.get("valid", False))

    if not ok:
        return False, f"windows_agent_error status={r.status_code} data={data}"

    if valid:
        return True, ""

    # invalid credentials / could not validate
    tail = str(data.get("log_tail") or "").strip()
    if tail:
        return False, tail[:1000]
    return False, "Invalid MT5 credentials (or MT5 log not found yet)"

def handle_validate_once() -> None:
    base = HANDOFF / "free"
    if not base.exists():
        return

    for req_str in glob.glob(str(base / "*" / "validate_request.json")):
        req = Path(req_str)
        udir = req.parent
        cred_path = udir / "validate_cred.json"
        res_path = udir / "validate_result.json"

        print(f"[validate] found request={req}", flush=True)

        try:
            if not cred_path.exists():
                _write_json_atomic(res_path, {"ok": False, "error": "missing validate_cred.json"})
                print(f"[validate] missing cred -> wrote result={res_path}", flush=True)
                continue

            cred = json.loads(cred_path.read_text(encoding="utf-8"))
            login = str(cred.get("login", "")).strip()
            password = str(cred.get("password", "")).strip()
            server = str(cred.get("server", "")).strip()

            if not (login and password and server):
                _write_json_atomic(res_path, {"ok": False, "error": "missing login/password/server"})
                print(f"[validate] missing fields -> wrote result={res_path}", flush=True)
                continue

            ok, err = _validate_via_agent(login, password, server)
            _write_json_atomic(res_path, {"ok": ok, "error": err})
            print(f"[validate] wrote result={res_path} ok={ok}", flush=True)
            if not ok:
                print(f"[validate] error={err[:200]}", flush=True)

        except Exception as e:
            _write_json_atomic(res_path, {"ok": False, "error": f"validate_worker_error: {type(e).__name__}: {e}"})
            print(f"[validate] exception {type(e).__name__}: {e}", flush=True)

        finally:
            # EPHEMERAL cleanup: request + cred
            for p in (req, cred_path):
                try:
                    p.unlink()
                except FileNotFoundError:
                    pass

def main() -> None:
    print("[validate] mt5_validate_worker starting (WINDOWS)", flush=True)
    while True:
        handle_validate_once()
        time.sleep(1)

if __name__ == "__main__":
    main()
