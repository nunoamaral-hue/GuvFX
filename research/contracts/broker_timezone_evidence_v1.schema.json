{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://guvfx.local/schema/broker_timezone_evidence_v1.schema.json",
  "title": "GuvFX Broker Timezone Evidence v1",
  "description": "Evidence for a broker server timezone assessment. No default offset exists; a VERIFIED assessment is required before normalising timestamps. Synthetic/design contract under GFX-PKT-006C; synthetic fixtures may carry clearly-labelled invented observations.",
  "version": "1.0",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "instant_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$", "maxLength": 64 },
    "scope_slug": { "type": "string", "pattern": "^(?=.*[a-z])[a-z0-9][a-z0-9_-]*$", "maxLength": 64 },
    "sha256_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "properties": {
    "schema_version": { "const": "1.0" },
    "source_id": { "$ref": "#/definitions/slug" },
    "account_scope": { "$ref": "#/definitions/scope_slug" },
    "assessment_status": {
      "type": "string",
      "enum": ["VERIFIED", "INCONCLUSIVE", "CONFLICT"]
    },
    "evidence_method": { "type": "string", "minLength": 1, "maxLength": 256 },
    "assessed_at_utc": { "$ref": "#/definitions/instant_utc" },
    "covered_start_utc": { "$ref": "#/definitions/instant_utc" },
    "covered_end_utc": { "$ref": "#/definitions/instant_utc" },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "observed_at_utc": { "$ref": "#/definitions/instant_utc" },
          "server_clock_epoch_s": { "type": "integer" },
          "utc_clock_epoch_s": { "type": "integer" },
          "implied_offset_seconds": { "type": "integer" }
        },
        "required": [
          "observed_at_utc", "server_clock_epoch_s", "utc_clock_epoch_s",
          "implied_offset_seconds"
        ]
      }
    },
    "dst_behaviour": { "type": "string", "minLength": 1, "maxLength": 256 },
    "evidence_fingerprint": { "$ref": "#/definitions/sha256_hex" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "schema_version", "source_id", "account_scope", "assessment_status",
    "evidence_method", "assessed_at_utc", "covered_start_utc", "covered_end_utc",
    "observations", "dst_behaviour", "evidence_fingerprint", "limitations"
  ]
}
