{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://guvfx.local/schema/raw_market_data_manifest_v1.schema.json",
  "title": "GuvFX Raw Market-Data Manifest v1",
  "description": "Manifest for an immutable raw market-data object (accepted or quarantined). All paths are root-relative; absolute paths are forbidden. Synthetic/design contract under GFX-PKT-006C.",
  "version": "1.0",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "instant_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "minute_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:00Z$"
    },
    "sha256_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rel_path": {
      "type": "string",
      "description": "Safe root-relative path: '/'-separated segments, each starting with [A-Za-z0-9_-] (no leading dot) then [A-Za-z0-9_.-]; no absolute path, backslash, empty segment, '.' or '..'.",
      "pattern": "^[A-Za-z0-9_-][A-Za-z0-9_.-]*(/[A-Za-z0-9_-][A-Za-z0-9_.-]*)*$",
      "maxLength": 512
    },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$", "maxLength": 64 },
    "scope_slug": { "type": "string", "pattern": "^(?=.*[a-z])[a-z0-9][a-z0-9_-]*$", "maxLength": 64 }
  },
  "properties": {
    "schema_version": { "const": "1.0" },
    "raw_object_id": { "$ref": "#/definitions/sha256_hex" },
    "object_state": { "type": "string", "enum": ["ACCEPTED", "QUARANTINED"] },
    "source_id": { "$ref": "#/definitions/slug" },
    "account_scope": { "$ref": "#/definitions/scope_slug" },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9]{3,12}$" },
    "timeframe": { "type": "string", "enum": ["M1"] },
    "representation": { "type": "string", "enum": ["bid_ohlc"] },
    "range_start_utc": { "$ref": "#/definitions/minute_utc" },
    "range_end_utc": { "$ref": "#/definitions/minute_utc" },
    "range_semantics": { "const": "[start,end)" },
    "acquired_at_utc": { "$ref": "#/definitions/instant_utc" },
    "received_at_utc": { "$ref": "#/definitions/instant_utc" },
    "request_schema_id": { "type": "string", "minLength": 1 },
    "response_schema_id": { "type": "string", "minLength": 1 },
    "request_sha256": { "$ref": "#/definitions/sha256_hex" },
    "response_sha256": { "$ref": "#/definitions/sha256_hex" },
    "request_path": { "$ref": "#/definitions/rel_path" },
    "response_path": { "$ref": "#/definitions/rel_path" },
    "manifest_path": { "$ref": "#/definitions/rel_path" },
    "code_commit": { "type": "string", "minLength": 1 },
    "timezone_status": {
      "type": "string",
      "enum": ["NOT_EVALUATED", "VERIFIED", "INCONCLUSIVE", "CONFLICT"]
    },
    "quarantine_reason": { "type": ["string", "null"] },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "schema_version", "raw_object_id", "object_state", "source_id", "account_scope",
    "symbol", "timeframe", "representation", "range_start_utc", "range_end_utc",
    "range_semantics", "acquired_at_utc", "received_at_utc", "request_schema_id",
    "response_schema_id", "request_sha256", "response_sha256", "request_path",
    "response_path", "manifest_path", "code_commit", "timezone_status",
    "quarantine_reason", "limitations"
  ]
}
