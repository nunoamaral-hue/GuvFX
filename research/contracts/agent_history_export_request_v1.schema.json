{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://guvfx.local/schema/agent_history_export_request_v1.schema.json",
  "title": "GuvFX Agent History Export Request v1",
  "description": "Read-only MT5 history export request for the future Windows Agent endpoint. Contains no login, account number, password, token or server credential. Synthetic/design contract; no live call is made under GFX-PKT-006C.",
  "version": "1.0",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "minute_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:00Z$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "maxLength": 64
    },
    "scope_slug": {
      "type": "string",
      "pattern": "^(?=.*[a-z])[a-z0-9][a-z0-9_-]*$",
      "maxLength": 64
    },
    "sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "properties": {
    "schema_version": { "const": "1.0" },
    "operation": { "const": "copy_rates_range" },
    "source_id": { "$ref": "#/definitions/slug" },
    "account_scope": { "$ref": "#/definitions/scope_slug" },
    "symbol": { "type": "string", "pattern": "^[A-Z0-9]{3,12}$" },
    "timeframe": { "type": "string", "enum": ["M1"] },
    "representation": { "type": "string", "enum": ["bid_ohlc"] },
    "range_start_utc": { "$ref": "#/definitions/minute_utc" },
    "range_end_utc": { "$ref": "#/definitions/minute_utc" },
    "range_semantics": { "const": "[start,end)" },
    "request_id": { "$ref": "#/definitions/sha256_hex" }
  },
  "required": [
    "schema_version",
    "operation",
    "source_id",
    "account_scope",
    "symbol",
    "timeframe",
    "representation",
    "range_start_utc",
    "range_end_utc",
    "range_semantics",
    "request_id"
  ]
}
