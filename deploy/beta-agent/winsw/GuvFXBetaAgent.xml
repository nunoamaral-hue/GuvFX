<service>
  <!-- WinSW service definition for the GuvFX beta provisioning agent.
       WinSW (a standalone .NET wrapper) runs the DEDICATED VENV python as a child; it writes nothing to
       System32 or the base interpreter, so the production Python is never part of the beta runtime.
       DARK / INSTALL-ONLY: startmode Manual (no autostart), recovery disabled - nothing auto-starts before
       the first-start authorisation. -->
  <id>GuvFXBetaAgent</id>
  <name>GuvFX Beta Provisioning Agent</name>
  <description>GuvFX beta per-slot provisioning agent. Runs the venv python; least-privilege virtual account.</description>

  <executable>C:\GuvFX\beta\agent-venv\Scripts\python.exe</executable>
  <arguments>-u C:\GuvFX\beta\agent\agent.py</arguments>
  <workingdirectory>C:\GuvFX\beta\agent</workingdirectory>

  <!-- Least privilege: the SCM-created virtual account, no password. <allowservicelogon>true</> is REQUIRED
       for WinSW v2.12.0 to actually apply this account. HOST-PROVEN 2026-07-24: WITHOUT it WinSW ignores
       <username> and silently installs the service as LocalSystem (the installer's -Apply verify caught that
       and refused to start). This CORRECTS review finding F2, which hypothesised the opposite - the feared
       pre-registration LSA name->SID resolve does NOT occur, because CreateService auto-provisions the
       NT SERVICE\<id> virtual account, so WinSW's SeServiceLogonRight grant resolves against an existing
       account. This is the identity assignment pywin32's `sc config obj=` failed to make; the -Apply verify
       still FAILS CLOSED if StartName is not exactly this account. -->
  <serviceaccount>
    <username>NT SERVICE\GuvFXBetaAgent</username>
    <allowservicelogon>true</allowservicelogon>
  </serviceaccount>

  <!-- Manual: the operator starts it under a separate authorisation. Never Automatic. -->
  <startmode>Manual</startmode>

  <!-- WinSW captures the child's stdout/stderr to rolling logs, separate from the agent's own state logs. -->
  <logpath>C:\GuvFX\beta\agent-state\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>

  <!-- Graceful stop: WinSW signals the console child (Ctrl+C), bounded by stoptimeout, so agent.py's
       main() catches KeyboardInterrupt and drains in-flight mutating ops before exit, THEN WinSW
       force-terminates. stoptimeout MUST exceed BETA_AGENT_DRAIN_TIMEOUT_S (config; >30s settle floor, no
       documented ceiling) or a stop force-kills a mutation mid-drain (B-6). Set well above any expected
       drain; install_service.ps1 additionally ASSERTS stoptimeout > the configured drain at install time,
       so raising the drain past this value fails the install rather than silently truncating a drain. -->
  <stoptimeout>300 sec</stoptimeout>
  <stopparentprocessfirst>true</stopparentprocessfirst>

  <!-- Recovery DISABLED for the first install: nothing may auto-restart before approval. -->
  <onfailure action="none" />
</service>
